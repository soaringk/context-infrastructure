# ============================================================
# .env.example — 所有需要的环境变量
# 复制为 .env 并填写你自己的值
# ============================================================

# Gmail（用于 send_email / crontab_monitor 告警邮件）
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_RECIPIENTS=

# OpenCode Server（用于 observer / reflector / newsletter / crontab_monitor）
OPENCODE_BASE_URL=http://localhost:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=

# Google Analytics 4（用于 ga4_metrics.py）
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Kit / ConvertKit（用于 kit_metrics.py 和 newsletter 发布）
KIT_API_KEY=

# Typefully（用于 typefully_metrics.py，需从浏览器抓取）
TYPEFULLY_AUTHORIZATION=
TYPEFULLY_ACCOUNT=
TYPEFULLY_SESSION=

# Gemini（用于图片生成）
GEMINI_API_KEY=
# 或者使用 GOOGLE_API_KEY（二选一）

# OpenAI（用于 semantic_search 本地 embedding）
OPENAI_API_KEY=
